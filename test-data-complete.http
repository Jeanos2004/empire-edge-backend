Authorization: Bearer {{client1Token}}
Content-Type: application/json

{
  "event_type": "mariage_moderne",
  "event_category": "prive_familial",
  "title": "Mariage de Jean et Sophie",
  "event_date": "2025-12-25T18:00:00Z",
  "guest_count": 200,
  "budget_min": 10000000,
  "budget_max": 15000000,
  "style": "moderne",
  "is_hybrid": false,
  "description": "Grand mariage avec réception"
}

