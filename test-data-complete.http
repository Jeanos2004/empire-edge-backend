POST {{baseUrl}}/messages-send-message
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "event_id": "EVENT_1_ID",
  "recipient_id": "CLIENT_1_ID",
  "subject": "Re: Question sur le menu",
  "content": "Bien sûr! Nous pouvons ajouter plus d'options végétariennes. Je vous enverrai un menu révisé demain."
}

