### Variables
@baseUrl = https://YOUR_PROJECT_REF.supabase.co/functions/v1
@authToken = YOUR_JWT_TOKEN_HERE

### Test 1 - Supprimer événement (cas nominal)
DELETE {{baseUrl}}/events/delete-event
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "event_id": "event-uuid-here"
}

### Test 2 - Erreur: event_id manquant
DELETE {{baseUrl}}/events/delete-event
Authorization: Bearer {{authToken}}
Content-Type: application/json

{}

### Test 3 - Erreur: événement avec devis accepté
DELETE {{baseUrl}}/events/delete-event
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "event_id": "event-with-accepted-quote-uuid"
}

### Test 4 - Erreur: événement avec paiements
DELETE {{baseUrl}}/events/delete-event
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "event_id": "event-with-payments-uuid"
}

### Test 5 - Erreur: accès non autorisé
DELETE {{baseUrl}}/events/delete-event
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "event_id": "autre-client-event-uuid"
}

